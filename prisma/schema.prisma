generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProjectStatus {
  enquiry
  design
  approved
  in_production
  ready
  dispatched
  installed
  closed
}

enum UserRole {
  admin
  director
  designer
  production_manager
  shop_floor
  procurement
  viewer
}

enum MaterialCategory {
  board
  veneer
  solid_timber
  laminate
  glass
  edge_banding
}

enum GrainDirection {
  none
  length
  width
}

enum HardwareCategory {
  hinges
  drawer_runners
  handles_knobs
  legs
  shelf_pins
  soft_close
  lighting
  other
}

enum CutListStatus {
  draft
  approved
  superseded
}

enum CabinetType {
  base_cabinet
  wall_cabinet
  tall_unit
  drawer_unit
  open_shelf
}

enum ProductionStageName {
  cutting
  edge_banding
  drilling_cnc
  assembly
  finishing
  quality_check
  dispatch
}

enum StageStatus {
  pending
  in_progress
  completed
  blocked
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  role           UserRole
  avatarInitials String   @db.VarChar(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  designedProjects   Project[]        @relation("Designer")
  managedProjects    Project[]        @relation("ProductionManager")
  createdProjects    Project[]        @relation("CreatedBy")
  generatedCutLists  CutListVersion[] @relation("CutListGenerator")
  assignedStages     ProductionStage[] @relation("StageAssignee")
}

model Customer {
  id          String   @id @default(cuid())
  companyName String
  contactName String
  email       String
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
}

model Project {
  id                  String        @id @default(cuid())
  projectCode         String        @unique
  siteAddress         String
  status              ProjectStatus @default(enquiry)
  enquiryDate         DateTime      @db.Date
  startDate           DateTime      @db.Date
  deliveryDate        DateTime      @db.Date
  estimatedValue      Int
  internalNotes       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])

  designerId          String
  designer            User     @relation("Designer", fields: [designerId], references: [id])

  productionManagerId String?
  productionManager   User?    @relation("ProductionManager", fields: [productionManagerId], references: [id])

  createdById         String
  createdBy           User     @relation("CreatedBy", fields: [createdById], references: [id])

  rooms            Room[]
  cutListVersions  CutListVersion[]
  cabinets         Cabinet[]
  productionStages ProductionStage[]
}

model Room {
  id            String    @id @default(cuid())
  name          String
  sequenceOrder Int
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cabinets      Cabinet[]
}

model Material {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  category         MaterialCategory
  supplier         String
  sheetLengthMm    Int
  sheetWidthMm     Int
  thicknessMm      Int
  costPerSheet     Float
  wastagePct       Float            @default(10)
  grainDirection   GrainDirection   @default(none)
  edgeBandingCodes String[]
  active           Boolean          @default(true)
  minOrderQty      Int              @default(1)
  leadTimeDays     Int              @default(14)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  cutListItems        CutListItem[]
  carcassCabinets     Cabinet[]     @relation("CarcassMaterial")
  backCabinets        Cabinet[]     @relation("BackMaterial")
  doorCabinets        Cabinet[]     @relation("DoorMaterial")
  drawerFrontCabinets Cabinet[]     @relation("DrawerFrontMaterial")
}

model Hardware {
  id            String           @id @default(cuid())
  code          String           @unique
  name          String
  category      HardwareCategory
  supplier      String
  unitCost      Float
  uom           String
  finish        String?
  loadRating    String?
  minStockLevel Int              @default(0)
  reorderQty    Int              @default(10)
  active        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  hingeCabinets  Cabinet[] @relation("CabinetHinge")
  runnerCabinets Cabinet[] @relation("CabinetRunner")
  handleCabinets Cabinet[] @relation("CabinetHandle")
}

model Cabinet {
  id                    String      @id @default(cuid())
  cabinetCode           String
  description           String?
  type                  CabinetType
  widthMm               Int
  heightMm              Int
  depthMm               Int
  qty                   Int         @default(1)
  doorCount             Int         @default(0)
  drawerCount           Int         @default(0)
  shelfCount            Int         @default(0)
  finishSpec            String?
  notes                 String?
  sequenceOrder         Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  projectId             String
  project               Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  roomId                String?
  room                  Room?       @relation(fields: [roomId], references: [id])

  carcassMaterialId     String
  carcassMaterial       Material    @relation("CarcassMaterial", fields: [carcassMaterialId], references: [id])

  backMaterialId        String?
  backMaterial          Material?   @relation("BackMaterial", fields: [backMaterialId], references: [id])

  doorMaterialId        String?
  doorMaterial          Material?   @relation("DoorMaterial", fields: [doorMaterialId], references: [id])

  drawerFrontMaterialId String?
  drawerFrontMaterial   Material?   @relation("DrawerFrontMaterial", fields: [drawerFrontMaterialId], references: [id])

  hingeHardwareId       String?
  hingeHardware         Hardware?   @relation("CabinetHinge", fields: [hingeHardwareId], references: [id])

  runnerHardwareId      String?
  runnerHardware        Hardware?   @relation("CabinetRunner", fields: [runnerHardwareId], references: [id])

  handleHardwareId      String?
  handleHardware        Hardware?   @relation("CabinetHandle", fields: [handleHardwareId], references: [id])
}

model CutListVersion {
  id          String        @id @default(cuid())
  versionNo   Int
  status      CutListStatus @default(draft)
  generatedAt DateTime      @default(now())

  projectId   String
  project     Project @relation(fields: [projectId], references: [id])

  generatedBy String
  generator   User    @relation("CutListGenerator", fields: [generatedBy], references: [id])

  items CutListItem[]

  @@unique([projectId, versionNo])
}

model CutListItem {
  id          String         @id @default(cuid())
  partCode    String
  description String
  lengthMm    Int
  widthMm     Int
  thicknessMm Int
  qty         Int
  grainDir    GrainDirection @default(none)
  edgeBanding String         @default("")
  finish      String?
  cabinetRef  String?
  notes       String?

  versionId String
  version   CutListVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  materialId String
  material   Material @relation(fields: [materialId], references: [id])
}

model ProductionStage {
  id           String              @id @default(cuid())
  stage        ProductionStageName
  status       StageStatus         @default(pending)
  startedAt    DateTime?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?   @relation("StageAssignee", fields: [assignedToId], references: [id])

  @@unique([projectId, stage])
}
