# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app

# ─── Database (Railway Postgres — copy from Railway dashboard) ────────────────
DATABASE_URL=postgresql://user:password@host:5432/walnut_erp

# ─── Redis (Railway Redis — copy from Railway dashboard) ──────────────────────
REDIS_URL=redis://default:password@host:6379

# ─── Auth (NextAuth — add when auth module is built) ──────────────────────────
NEXTAUTH_SECRET=replace-with-32-char-random-string
NEXTAUTH_URL=https://your-app.up.railway.app

# ─── File storage (S3 / Cloudflare R2 — add when file uploads are built) ──────
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# ─── Email (Resend — add when quotation emails are built) ─────────────────────
# RESEND_API_KEY=
